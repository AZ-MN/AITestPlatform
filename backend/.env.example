# 后端环境配置示例，复制为 .env 并修改
PROJECT_NAME=AI智能测试平台
API_V1_STR=/api/v1
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/ai_test_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM 配置（默认 OpenAI 兼容格式）
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 文件存储
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# 通知
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
